# Copy to .env and fill in. NEVER commit the real .env.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Hides /docs and /redoc, tightens behaviour.
ENVIRONMENT=production

# Rate limiting (protects your OpenAI budget)
PER_IP_MAX=8
PER_IP_WINDOW_SECONDS=600
GLOBAL_DAILY_MAX=500

# Model / payload limits
MAX_OUTPUT_TOKENS=300
MAX_INPUT_CHARS=600
MAX_HISTORY=6

# Allowed CORS origins (comma-separated). In production the frontend is
# same-origin via Nginx, so this is mostly a safety net.
ALLOWED_ORIGINS=https://ericfolch.com
