---
import { profile } from "../data/profile";
---

<section id="about" class="py-16 md:py-24">
  <div class="container-x">
    <h2 class="display text-4xl sm:text-5xl">
      <span class="block">About</span>
      <span class="ghost block">Me</span>
    </h2>

    <!-- Title spans the left edge; the body is indented to the centre column. -->
    <div class="mt-10 md:grid md:grid-cols-[200px_1fr] md:gap-16">
      <div class="md:col-start-2">
        <div class="max-w-2xl space-y-4 text-base leading-relaxed text-ink/80 md:text-lg">
          {profile.about.map((p) => <p>{p}</p>)}
        </div>

        <!-- Languages: own block with card treatment for prominence. -->
        <div class="mt-12">
          <p class="eyebrow mb-5">Languages</p>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            {
              profile.languages.map((lang) => (
                <div class="rounded-xl border border-line bg-surface/40 px-4 py-4">
                  <p class="font-display text-xl font-bold">{lang.name}</p>
                  <p class="mt-1 text-xs uppercase tracking-wide text-muted">{lang.level}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
