---
import Chat from "./Chat.tsx";
---

<section id="ask-ai" class="py-16 md:py-24">
  <div class="container-x grid gap-8 md:grid-cols-[200px_1fr] md:gap-16">
    <div>
      <span class="inline-block h-1 w-10 bg-accent"></span>
      <p class="rail-label mt-4">Ask AI</p>
    </div>

    <div>
      <h2 class="display text-4xl sm:text-5xl">
        <span class="block">Ask my</span>
        <span class="ghost block">AI anything</span>
      </h2>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">
        A small assistant that answers questions about my background, projects and
        skills. It runs on a self-hosted FastAPI proxy with curated context and
        rate limiting — no API keys ever touch the browser.
      </p>

      <div class="mt-8">
        <!-- Hydrated only when scrolled into view: keeps the page static & fast. -->
        <Chat client:visible />
      </div>

      <p class="mt-4 text-xs text-muted">
        <a href="#how-it-works" class="underline-offset-2 hover:underline">
          How this chat works ↓
        </a>
      </p>
    </div>
  </div>
</section>
