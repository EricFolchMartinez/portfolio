---
import { profile } from "../data/profile";
const [bright, ghost] = profile.headlineLines;
---

<section id="top" class="container-x pt-32 pb-16 md:pt-40 md:pb-20">
  <p class="eyebrow mb-6 flex items-center gap-2">
    <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent"></span>
    Available for internships
  </p>

  <h1 class="display text-6xl sm:text-7xl lg:text-[8.5rem]">
    <span class="block">{bright}</span>
    <span class="ghost block">{ghost}</span>
  </h1>

  <p class="mt-8 max-w-2xl text-lg leading-relaxed text-muted md:text-xl">
    {profile.intro}
  </p>

  <div class="mt-10 flex flex-wrap items-center gap-3">
    <a
      href="#projects"
      class="rounded-full bg-ink px-6 py-3 text-sm font-medium text-bg transition-opacity hover:opacity-90"
    >
      View projects
    </a>
    <a
      href={profile.cvPath}
      download
      class="rounded-full border border-line px-6 py-3 text-sm font-medium transition-colors hover:border-ink/40"
    >
      Download CV
    </a>

    <span class="mx-1 hidden h-5 w-px bg-line sm:block"></span>

    {
      profile.socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-muted transition-colors hover:text-ink"
        >
          {s.label}
        </a>
      ))
    }
  </div>
</section>
